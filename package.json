{
  "name": "vmail",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.1.0",
  "description": "使用 Cloudflare email worker 实现的临时电子邮件服务",
  "scripts": {
    "build": "pnpm --filter frontend run build",
    "test": "node --test worker/src/*.test.ts",
    "typecheck": "pnpm --filter frontend run typecheck",
    "deploy": "pnpm build && wrangler deploy",
    "dev": "wrangler dev",
    "worker:dev": "pnpm --filter worker run dev",
    "frontend:dev": "pnpm --filter frontend run dev",
    "format": "prettier --write ."
  },
  "keywords": [
    "vmail",
    "temp-email",
    "cloudflare-worker"
  ],
  "author": "oiov",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22"
  },
  "devDependencies": {
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.5.14",
    "wrangler": "^4.111.0"
  },
  "dependencies": {
    "@libsql/client": "0.4.0-pre.7",
    "@tanstack/react-query": "^5.90.3",
    "date-fns": "^3.6.0",
    "drizzle-orm": "^0.29.5",
    "drizzle-zod": "^0.5.1",
    "hono": "^4.5.1",
    "mimetext": "^3.0.28",
    "nanoid": "^5.0.7",
    "postal-mime": "^2.0.2",
    "zod": "^3.25.76"
  }
}
